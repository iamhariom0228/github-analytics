# GitHub OAuth App credentials
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=https://your-app.fly.dev/api/v1/auth/github/callback
GITHUB_WEBHOOK_SECRET=your_random_webhook_secret

# JWT — generate: openssl rand -base64 32
JWT_SECRET=your_256_bit_secret_here

# AES-256-GCM key for encrypting GitHub tokens — must be 32 bytes
ENCRYPTION_KEY=your_exactly_32_byte_aes_key_here!

# Database (Supabase connection pooling URL)
DATABASE_URL=jdbc:postgresql://db.xxxx.supabase.co:6543/postgres
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_supabase_password

# Redis (Upstash)
REDIS_URL=rediss://default:your_token@your-endpoint.upstash.io:6379

# Kafka (Upstash Kafka)
KAFKA_BOOTSTRAP_SERVERS=your-endpoint.upstash.io:9092
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_SASL_JAAS_CONFIG=org.apache.kafka.common.security.scram.ScramLoginModule required username="your_user" password="your_pass";

# Email (Resend)
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=digest@yourdomain.com

# CORS — your Vercel frontend URL
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# Frontend URL (for OAuth redirect after login)
FRONTEND_URL=https://your-app.vercel.app
