# GitHub OAuth App credentials
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=https://YOUR_DOMAIN.duckdns.org/api/v1/auth/github/callback
GITHUB_WEBHOOK_SECRET=your_random_webhook_secret

# JWT — generate: openssl rand -hex 32
JWT_SECRET=your_256_bit_secret_here

# AES-256-GCM key — must be exactly 32 chars
ENCRYPTION_KEY=your_exactly_32_byte_aes_key_here!

# PostgreSQL (runs in Docker on the same VM)
POSTGRES_USER=gitanalytics
POSTGRES_PASSWORD=your_strong_db_password

# Redis runs on the same VM — no external URL needed
# (docker-compose.prod.yml wires REDIS_URL=redis://redis:6379 automatically)

# CORS / OAuth redirects
CORS_ALLOWED_ORIGINS=https://<your-app>.vercel.app
FRONTEND_URL=https://<your-app>.vercel.app
COOKIE_SECURE=true

# Optional
GROQ_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
