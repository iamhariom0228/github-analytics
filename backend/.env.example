# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# Create at: github.com/settings/developers → OAuth Apps → New
# Callback URL (local):  http://localhost:8080/api/v1/auth/github/callback
# Callback URL (Render): https://<your-service>.onrender.com/api/v1/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8080/api/v1/auth/github/callback
GITHUB_WEBHOOK_SECRET=

# ── Secrets ───────────────────────────────────────────────────────────────────
# JWT: generate with → openssl rand -hex 32   (must be 32+ chars)
JWT_SECRET=changeme-use-256-bit-secret-in-production-env-var
# Encryption: must be EXACTLY 32 characters for AES-256-GCM
ENCRYPTION_KEY=changeme-32-byte-key-for-aes-gcm!

# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker:  leave as-is (wired by docker-compose)
# Render:        paste the "JDBC Connection String" from the Render DB dashboard
#                e.g. jdbc:postgresql://host:5432/gitanalytics?sslmode=require
DATABASE_URL=jdbc:postgresql://localhost:5432/gitanalytics
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local Docker:  leave as-is
# Render/prod:   paste the rediss:// URL from Upstash (upstash.com)
REDIS_URL=redis://localhost:6379

# ── CORS / Cookie ─────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
COOKIE_SECURE=false

# ── Optional ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=
